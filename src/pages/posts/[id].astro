---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const coverImageSrc = post.data.coverImage
  ? `/images/${post.data.coverImage}`
  : undefined;

const allPosts = await getCollection('posts');
const currentTags = post.data.tags ?? [];

const relatedPosts = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      (p.data.tags ?? []).some((tag) => currentTags.includes(tag))
  )
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<BaseLayout
  title={post.data.title}
  description={post.data.title}
  ogImage={coverImageSrc}
>
  <article>
    <header class="mb-8">
      <time class="text-sm text-gray-400">
        {post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="text-2xl font-bold mt-2 leading-snug">{post.data.title}</h1>

      {post.data.categories.length > 0 && (
        <div class="mt-3 flex gap-2 flex-wrap">
          {post.data.categories.map((cat) => (
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-0.5 rounded">{cat}</span>
          ))}
        </div>
      )}

      {coverImageSrc && (
        <img
          src={coverImageSrc}
          alt={post.data.title}
          class="mt-4 w-full rounded-lg object-cover max-h-64"
          loading="lazy"
        />
      )}
    </header>

    <div class="prose prose-gray max-w-none">
      <Content />
    </div>

    {post.data.tags.length > 0 && (
      <footer class="mt-8 pt-4 border-t border-gray-100">
        <div class="flex gap-2 flex-wrap">
          {post.data.tags.map((tag) => (
            <span class="text-xs text-gray-500 bg-gray-50 px-2 py-0.5 rounded">#{tag}</span>
          ))}
        </div>
      </footer>
    )}

    {relatedPosts.length > 0 && (
      <section class="mt-10 pt-6 border-t border-gray-100">
        <h2 class="text-base font-bold text-gray-700 mb-4">関連記事</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {relatedPosts.map((related) => {
            const relatedCover = related.data.coverImage
              ? `/images/${related.data.coverImage}`
              : undefined;
            return (
              <li>
                <a
                  href={`/posts/${related.id}`}
                  class="flex gap-3 p-3 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors"
                >
                  {relatedCover && (
                    <img
                      src={relatedCover}
                      alt={related.data.title}
                      class="w-20 h-16 object-cover rounded flex-shrink-0"
                      loading="lazy"
                    />
                  )}
                  <div class="flex flex-col justify-center min-w-0">
                    <time class="text-xs text-gray-400">
                      {related.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <p class="text-sm font-medium text-gray-800 leading-snug mt-0.5 line-clamp-2">
                      {related.data.title}
                    </p>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    )}
  </article>

  <div class="mt-8">
    <a href="/" class="text-sm text-blue-600 hover:underline">← 記事一覧に戻る</a>
  </div>
</BaseLayout>
