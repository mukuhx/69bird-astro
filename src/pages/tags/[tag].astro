---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');

  const tagsMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      if (!tagsMap.has(tag)) tagsMap.set(tag, []);
      tagsMap.get(tag)!.push(post);
    }
  }

  return Array.from(tagsMap.entries()).map(([tag, posts]) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.sort((a, b) =>
        (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0)
      ),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`タグ: ${tag} | 69bird.jp`}>
  <nav class="text-sm text-gray-500 mb-6">
    <a href="/" class="hover:text-gray-700">トップ</a>
    <span class="mx-2">›</span>
    <a href="/tags/" class="hover:text-gray-700">タグ一覧</a>
    <span class="mx-2">›</span>
    <span>#{tag}</span>
  </nav>

  <h1 class="text-2xl font-bold mb-2">#{tag}</h1>
  <p class="text-sm text-gray-500 mb-6">{posts.length} 本の記事</p>

  <ul class="divide-y divide-gray-100">
    {posts.map((post) => (
      <li class="py-4">
        <a href={`/posts/${post.id}/`} class="group block">
          <time class="text-xs text-gray-400 block mb-1">
            {post.data.date
              ? post.data.date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })
              : ''}
          </time>
          <span class="text-base font-medium text-gray-900 group-hover:text-blue-600 leading-snug">
            {post.data.title}
          </span>
          {post.data.categories.length > 0 && (
            <span class="mt-1 flex gap-1 flex-wrap">
              {post.data.categories.map((cat) => (
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{cat}</span>
              ))}
            </span>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
